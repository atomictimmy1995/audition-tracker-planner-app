{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    // Pure modules (src/scheduler, src/ai, src/data) use explicit .ts import
    // extensions so Supabase Edge Functions (Deno) can share them verbatim.
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // _shared holds runtime-agnostic AI code shared by the app and the Deno edge
  // function; type-check it. Only the Deno entrypoint (ai/index.ts) is excluded
  // — it uses Deno globals and npm: specifiers tsc can't resolve.
  "include": ["app", "src", "scripts", "index.ts", "App.tsx", "supabase/functions/_shared"],
  "exclude": ["node_modules", "supabase/functions/ai"]
}
